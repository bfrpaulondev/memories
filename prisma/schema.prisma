generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Photo {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  guestName    String   @default("Convidado")
  mimeType     String   @default("image/jpeg")
  size         Int      @default(0)
  createdAt    DateTime @default(now())
}
